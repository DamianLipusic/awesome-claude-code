# Solana Trading Bot Environment Variables
# Copy this to .env and fill in your values

# Solana Wallet (Base58 encoded private key)
SOLANA_PRIVATE_KEY=

# RPC URL (recommended: Helius, QuickNode, or Alchemy)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Jupiter API (optional - for priority routing)
JUPITER_API_KEY=
